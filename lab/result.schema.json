{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rl-research run result",
  "type": "object",
  "required": [
    "run_id",
    "stage",
    "status",
    "primary_benchmark",
    "pillar",
    "thread",
    "seeds",
    "env_steps",
    "wallclock_s",
    "best_return",
    "final_return",
    "by_seed",
    "sanity",
    "git_sha",
    "started_at",
    "ended_at"
  ],
  "properties": {
    "run_id":            {"type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$"},
    "stage":             {"enum": ["A-only", "A+B"]},
    "status":            {"enum": ["sanity-failed", "benchmark-failed", "killed-budget", "killed-error", "completed"]},
    "primary_benchmark": {"type": "string"},
    "pillar":            {"enum": ["sparse-long-horizon", "long-horizon-dense", "multi-signal"]},
    "thread":            {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "seeds":             {"type": "array", "items": {"type": "integer"}, "minItems": 1},
    "env_steps":         {"type": "integer", "minimum": 0},
    "wallclock_s":       {"type": "number", "minimum": 0},
    "best_return": {
      "oneOf": [
        {"type": "number"},
        {"type": "array", "items": {"type": "number"}}
      ],
      "description": "Scalar for single-signal benchmarks; array for multi-signal (per channel)."
    },
    "final_return": {
      "oneOf": [
        {"type": "number"},
        {"type": "array", "items": {"type": "number"}}
      ]
    },
    "by_seed": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["best_return", "final_return", "env_steps"],
        "properties": {
          "best_return":  {"oneOf": [{"type": "number"}, {"type": "array", "items": {"type": "number"}}]},
          "final_return": {"oneOf": [{"type": "number"}, {"type": "array", "items": {"type": "number"}}]},
          "env_steps":    {"type": "integer"}
        }
      }
    },
    "sanity": {
      "type": "object",
      "required": ["passed", "by_env", "retries"],
      "properties": {
        "passed":  {"type": "boolean"},
        "retries": {"type": "integer", "minimum": 0},
        "by_env": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["return_random", "return_final", "passed"],
            "properties": {
              "return_random": {"type": "number"},
              "return_final":  {"type": "number"},
              "passed":        {"type": "boolean"}
            }
          }
        }
      }
    },
    "git_sha":     {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "started_at":  {"type": "string", "format": "date-time"},
    "ended_at":    {"type": "string", "format": "date-time"},
    "deps_lock":   {"type": "string"},
    "parent_run_id": {"type": ["string", "null"], "description": "Set on mass-run promotions."},
    "notes":       {"type": "string"}
  },
  "additionalProperties": false
}
